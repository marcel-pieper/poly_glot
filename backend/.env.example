APP_NAME=Polyglot API
APP_ENV=development
# Logs go to stderr and backend/logs/polyglot.log (archived daily as polyglot-YYYY-MM-DD.log).
# LOG_DIR=logs
# LOG_FILE=polyglot.log
# LOG_LEVEL=INFO
# LOG_BACKUP_DAYS=30
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/polyglot
JWT_SECRET=please-change-this-secret
JWT_EXPIRE_MINUTES=10080
VERIFICATION_CODE_TTL_MINUTES=10
OPENAI_API_KEY=
# Shared default for all OpenAI call sites unless overridden below.
# If unset, OPENAI_MODEL is used; if both unset, the code falls back to gpt-4o-mini.
OPENAI_MODEL_DEFAULT=gpt-5.3-chat-latest
# Optional overrides (omit to use the shared default above):
# OPENAI_MODEL_CHAT=
# OPENAI_MODEL_EXPLAIN=
# OPENAI_MODEL_CORRECT=
# OPENAI_MODEL_TRANSLATION=
OPENAI_MODEL_THREAD_TITLE=gpt-4o-mini

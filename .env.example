# Copy backend/.env.example to backend/.env and edit values as needed.
# Copy frontend/.env.example to frontend/.env and set your LAN API URL.

ngrok http 8001

docker compose up -d
cd backend
source venv/bin/activate   # or source .venv/bin/activate if that's your venv folder
alembic upgrade head
uvicorn app.main:app --reload --host 0.0.0.0 --port 8001

cd frontend
npm install
npx expo start --clear